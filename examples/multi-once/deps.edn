;; JVM/clojure-cli classpath for this example, so the `green` script can be
;; loaded from CIDER via `cider-jack-in-clj` (clojure-cli), not just run
;; under babashka. Mirrors what the script's babashka.deps/add-deps +
;; babashka.classpath/add-classpath do at runtime under bb:
;;   - green itself (:local/root "../..") and its transitive deps
;;   - babashka.fs, a bb built-in that must be a real dep on the JVM
;;   - this example's own resources/ (Selmer templates) on the classpath
{:paths ["resources"]
 :deps {io.github.amiorin/green {:local/root "../.."}
        babashka/fs {:mvn/version "0.5.22"}}}
